[Unit]
Description=DAVLOS OpenClaw Telegram Bot MVP
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root
Environment=TELEGRAM_BOT_ENV_FILE=/etc/davlos/secrets/openclaw/telegram-bot.env
Environment=TELEGRAM_BOT_LOG_LEVEL=INFO
ExecStart=/opt/control-plane/scripts/agents/openclaw/restricted_operator/run_telegram_bot.sh /opt/automation/agents/openclaw/broker/restricted_operator_policy.json
Restart=always
RestartSec=5
UMask=0077
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ProtectKernelTunables=true
ProtectControlGroups=true
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
ReadWritePaths=/opt/automation/agents/openclaw/broker /opt/automation/agents/openclaw/dropzone
ReadOnlyPaths=/opt/control-plane /etc/davlos/secrets/openclaw

[Install]
WantedBy=multi-user.target
